# ==========================================
# AIpolish - Desktop 模式 (Windows 本地运行)
# ==========================================
# Desktop 模式使用 SQLite + 内存队列，无需 MySQL 和 Redis

# 部署模式
DEPLOY_MODE=desktop

# ==========================================
# 1. 服务运行配置
# ==========================================
APP_HOST=127.0.0.1
APP_PORT=5000

# ==========================================
# 2. AI 模型默认全局配置
# ==========================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# ==========================================
# 3. 并发优化配置
# ==========================================
MAX_AI_WORKERS=8

# ==========================================
# 4. 管理员安全配置
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
