# ==========================================
# 1. 日志文件 (拦截运行脚本产生的 log)
# ==========================================
*.log
web_access.log
web_error.log
test_web_access.log
test_web_error.log

# ==========================================
# 2. 业务动态生成的数据目录 (绝对不能推送到远端)
# ==========================================
uploads/
outputs/

# ==========================================
# 3. 敏感环境变量配置文件 (防止密码/API Key泄露)
# ==========================================
.env
.env.*

# ==========================================
# 4. 虚拟环境
# ==========================================
venv/
env/
.venv/

# ==========================================
# 5. Python 编译缓存
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# 6. 编辑器与操作系统缓存
# ==========================================
.idea/
.vscode/
.DS_Store
Thumbs.db