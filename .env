# ==========================================
# 1. 基础服务运行配置 (IP & Port)
# ==========================================
APP_HOST=0.0.0.0
APP_PORT=80320

# ==========================================
# 2. MySQL 数据库配置
# 注意：HOST 只能填 IP 或域名，千万不要加 http:// 和 /
# ==========================================
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ai_polisher

# ==========================================
# 3. Redis 队列与通信配置
# 格式：redis://[:password]@host:port/db
# ==========================================
REDIS_URL=redis://:root@127.0.0.1:6379/0

# ==========================================
# 4. AI 模型默认全局配置
# ==========================================
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="your_model_name_here"

# ==========================================
# 5. 并发优化配置
# ==========================================
MAX_AI_WORKERS=20

# ==========================================
# 6. 管理员安全配置
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin