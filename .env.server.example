# ==========================================
# AIpolish - Server 模式 (Linux / Docker)
# ==========================================

# 部署模式
DEPLOY_MODE=server

# ==========================================
# 1. 服务运行配置
# ==========================================
APP_HOST=0.0.0.0
APP_PORT=5000

# ==========================================
# 2. MySQL 数据库配置
# ==========================================
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ai_polisher

# ==========================================
# 3. Redis 队列与通信配置
# ==========================================
REDIS_URL=redis://redis:6379/0

# ==========================================
# 4. AI 模型默认全局配置
# ==========================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# ==========================================
# 5. 并发优化配置
# ==========================================
MAX_AI_WORKERS=32

# ==========================================
# 6. 管理员安全配置
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
